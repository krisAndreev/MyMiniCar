@inherits LayoutComponentBase
@inject CartService CartService
@implements IDisposable

<div class="app-container">
    <header class="site-header">
        <NavMenu />
    </header>

    <main class="main-content">
        @Body
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row gy-5">
                <div class="col-lg-5">
                    <div class="brand mb-3">
                        <span class="brand-mark"><i class="bi bi-car-front-fill"></i></span>
                        MyMini<span>Car</span>
                    </div>
                    <p style="color: rgba(255,255,255,0.6); max-width: 26rem;">
                        We turn a photo of your car into a 3D-printed keyring tag — printed to order in real PLA filament and shipped worldwide.
                    </p>
                    <div class="footer-social mt-4">
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                        <a href="#" aria-label="X"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <h4 class="footer-title">Shop</h4>
                    <ul class="footer-links">
                        <li><a href="products">All keychains</a></li>
                        <li><a href="products">Bundles</a></li>
                        <li><a href="products">Premium</a></li>
                        <li><a href="products">Accessories</a></li>
                    </ul>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <h4 class="footer-title">Make</h4>
                    <ul class="footer-links">
                        <li><a href="convert">Open Studio</a></li>
                        <li><a href="about">How it works</a></li>
                        <li><a href="about">Materials</a></li>
                        <li><a href="about">Shipping</a></li>
                    </ul>
                </div>
                <div class="col-md-6 col-lg-3">
                    <h4 class="footer-title">Get 10% off your first tag</h4>
                    <p style="color: rgba(255,255,255,0.6);">New filament drops and offers, no spam.</p>
                    <div class="d-flex gap-2 mt-3">
                        <input type="email" placeholder="you@email.com" class="input-c" />
                        <button class="btn-primary-c"><i class="bi bi-arrow-right"></i></button>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <div>© @DateTime.Now.Year MyMiniCar. Printed to order with care.</div>
                <div class="d-flex gap-4">
                    <a href="#" style="color: rgba(255,255,255,0.6);">Privacy</a>
                    <a href="#" style="color: rgba(255,255,255,0.6);">Terms</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<!-- Cart Drawer -->
<div class="cart-backdrop @(CartService.IsCartOpen ? "show" : "")" @onclick="CloseCart"></div>
<div class="cart-drawer @(CartService.IsCartOpen ? "show" : "")">
    <div class="cart-head">
        <h3>Your cart</h3>
        <button class="close-x" @onclick="CloseCart"><i class="bi bi-x-lg"></i></button>
    </div>

    <div class="cart-body">
        @if (!CartService.Items.Any())
        {
            <div class="text-center py-5 text-soft">
                <i class="bi bi-bag" style="font-size: 2.4rem; color: var(--ink-faint);"></i>
                <p class="mt-3">Your cart is empty.</p>
                <button class="btn-primary-c btn-sm-c mt-2" @onclick="CloseAndGoStudio">Make a keychain</button>
            </div>
        }
        else
        {
            @foreach (var item in CartService.Items)
            {
                <div class="cart-item">
                    @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                    {
                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="cart-item-img" />
                    }
                    else
                    {
                        <div class="cart-item-img @item.Product.TileClass d-grid" style="place-items:center;">
                            <i class="bi bi-car-front-fill" style="color: rgba(255,255,255,0.85); font-size: 1.5rem;"></i>
                        </div>
                    }
                    <div class="cart-item-details flex-grow-1">
                        <div class="cart-item-name">@item.Product.Name</div>
                        <div class="cart-item-meta">@item.SelectedMaterial</div>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <div class="qty">
                                <button @onclick="() => DecreaseQty(item)"><i class="bi bi-dash"></i></button>
                                <span>@item.Quantity</span>
                                <button @onclick="() => IncreaseQty(item)"><i class="bi bi-plus"></i></button>
                            </div>
                            <span class="cart-item-price">@((item.Product.Price * item.Quantity).ToString("C2"))</span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @if (CartService.Items.Any())
    {
        <div class="cart-foot">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-soft">Subtotal</span>
                <span class="font-display" style="font-size: 1.3rem; font-weight: 700;">@CartService.GetTotal().ToString("C2")</span>
            </div>
            <button class="btn-primary-c btn-block btn-lg" @onclick="ProceedToCheckout">Checkout</button>
            <p class="text-center text-faint mt-3 mb-0" style="font-size: 0.74rem;">Free shipping over $40 · printed in 3–5 days</p>
        </div>
    }
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    protected override void OnInitialized() => CartService.OnChange += StateHasChanged;

    private void CloseCart() => CartService.IsCartOpen = false;

    private void CloseAndGoStudio()
    {
        CloseCart();
        Navigation.NavigateTo("convert");
    }

    private void IncreaseQty(CartItem item) => CartService.AddItem(item.Product, item.SelectedMaterial);
    private void DecreaseQty(CartItem item) => CartService.RemoveItem(item.Product.Id, item.SelectedMaterial);

    private void ProceedToCheckout()
    {
        CloseCart();
        Navigation.NavigateTo("checkout");
    }

    public void Dispose() => CartService.OnChange -= StateHasChanged;
}
