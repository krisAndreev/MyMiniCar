@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject LanguageService Language

<div class="car-model-viewer">
    <div class="car-model-stage" @ref="_stage"></div>
    <p class="text-faint m-0 car-model-hint">
        <i class="bi bi-arrows-move"></i> @(EnableZoom ? Language.T("Drag to rotate · scroll to zoom") : Language.T("Drag to rotate"))
    </p>
</div>

@code {
    [Parameter] public string Color { get; set; } = "#2D6CFF";
    [Parameter] public double Metalness { get; set; } = 0.35;
    [Parameter] public double Roughness { get; set; } = 0.45;
    [Parameter] public bool Emissive { get; set; }
    [Parameter] public string ModelUrl { get; set; } = "models/golf/untitled.gltf";
    [Parameter] public bool EnableZoom { get; set; } = true;
    [Parameter] public bool AutoRotate { get; set; }
    [Parameter] public bool Recolor { get; set; } = true;
    [Parameter] public double FitScale { get; set; } = 1;

    private ElementReference _stage;
    private IJSObjectReference? _module;
    private IJSObjectReference? _viewer;
    private string _applied = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/car-model-viewer.js");
        _viewer = await _module.InvokeAsync<IJSObjectReference>(
            "createViewer", _stage, ModelUrl, new { enableZoom = EnableZoom, autoRotate = AutoRotate, fitScale = FitScale });
        if (Recolor) await ApplyMaterial();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Recolor && _viewer is not null && Signature != _applied)
            await ApplyMaterial();
    }

    private string Signature => $"{Color}|{Metalness}|{Roughness}|{Emissive}";

    private async Task ApplyMaterial()
    {
        if (_viewer is null) return;
        await _viewer.InvokeVoidAsync("setMaterial", new
        {
            color = Color,
            metalness = Metalness,
            roughness = Roughness,
            emissive = Emissive
        });
        _applied = Signature;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_viewer is not null)
            {
                await _viewer.InvokeVoidAsync("dispose");
                await _viewer.DisposeAsync();
            }
            if (_module is not null)
                await _module.DisposeAsync();
        }
        catch (JSDisconnectedException) { }
    }
}
