@page "/login"
@using MyMiniCar.Web.Auth
@inject SupabaseAuthService Auth
@inject SupabaseAuthStateProvider AuthState
@inject NavigationManager Nav
@inject LanguageService Language

<PageTitle>Log in</PageTitle>
<div class="auth-wrap">
    <div class="auth-card">
        <span class="eyebrow">@Language.T("Welcome back")</span>
        <h1>@Language.T("Log in")</h1>
        <input type="email" placeholder="@Language.T("Email")" @bind="_email" />
        <input type="password" placeholder="@Language.T("Password")" @bind="_password" />
        <button class="btn-primary-c btn-block" disabled="@_busy" @onclick="DoLogin">
            @(_busy ? "…" : Language.T("Log in"))
        </button>
        @if (_error is not null) { <p class="auth-error">@_error</p> }
        <p>@Language.T("No account?") <a href="/register">@Language.T("Register")</a></p>
    </div>
</div>

@code {
    private string _email = "", _password = "";
    private string? _error;
    private bool _busy;

    private async Task DoLogin()
    {
        _busy = true; _error = null;
        _error = await Auth.LoginAsync(_email, _password);
        _busy = false;
        if (_error is null)
        {
            AuthState.NotifyChanged();
            Nav.NavigateTo("/");
        }
    }
}
