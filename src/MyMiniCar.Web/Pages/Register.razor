@page "/register"
@using MyMiniCar.Web.Auth
@inject SupabaseAuthService Auth
@inject SupabaseAuthStateProvider AuthState
@inject NavigationManager Nav
@inject LanguageService Language

<PageTitle>Register</PageTitle>
<div class="auth-wrap">
    <div class="auth-card">
        <span class="eyebrow">@Language.T("Join MyMiniCar")</span>
        <h1>@Language.T("Create account")</h1>
        <input placeholder="@Language.T("Full name")" @bind="_name" />
        <input type="email" placeholder="@Language.T("Email")" @bind="_email" />
        <input type="password" placeholder="@Language.T("Password")" @bind="_password" />
        <button class="btn-primary-c btn-block" disabled="@_busy" @onclick="DoRegister">
            @(_busy ? "…" : Language.T("Register"))
        </button>
        @if (_error is not null) { <p class="auth-error">@_error</p> }
        <p>@Language.T("Already have an account?") <a href="/login">@Language.T("Log in")</a></p>
    </div>
</div>

@code {
    private string _name = "", _email = "", _password = "";
    private string? _error;
    private bool _busy;

    private async Task DoRegister()
    {
        _busy = true; _error = null;
        _error = await Auth.RegisterAsync(_email, _password, _name);
        _busy = false;
        if (_error is null)
        {
            AuthState.NotifyChanged();
            Nav.NavigateTo("/");
        }
    }
}
