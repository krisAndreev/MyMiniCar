@page "/convert"
@inject CartService CartService
@inject LanguageService Language
@implements IDisposable

<div class="container py-5 studio-page">
    <div class="text-center mb-5">
        <span class="eyebrow">@Language.T("The Studio")</span>
        <h1 class="mt-3 mb-2">@Language.T("Get your own") @HeadingNoun</h1>
        <p class="text-soft mx-auto" style="max-width: 32rem;">
            @Language.T("Pick your car, make it yours — see it spin in 3D, live.")
        </p>
    </div>

    <div class="row g-4 g-lg-5">
        <div class="col-lg-6">
            <div class="preview-stage">
                <div class="preview-head">
                    <span class="label">@Language.T("Your") @HeadingNoun, @Language.T("live")</span>
                    <span class="d-inline-flex align-items-center gap-2 text-soft" style="font-size: 0.72rem;">
                        <span class="live-dot"></span> @Language.T("Updating live")
                    </span>
                </div>
                <div class="preview-canvas blueprint-soft">
                    <CarModelViewer @key="_car.Key"
                                    ModelUrl="@_car.GltfPath"
                                    Color="@_config.EffectiveColor(_bodyColor)"
                                    Metalness="_config.Material.Metalness"
                                    Roughness="_config.Material.Roughness"
                                    Emissive="_config.Material.Emissive" />
                </div>
                <div class="preview-foot">
                    <span><i class="bi bi-printer me-1"></i>@_car.Name · @Language.T(_config.Size.Name)</span>
                    <span class="mono">@_config.Price.ToString("C2")</span>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="studio-panel">
                <label class="field-label">@Language.T("Your model")</label>
                <div class="car-model-grid mb-4">
                    @foreach (var car in CarCatalog.All)
                    {
                        var model = car;
                        <button type="button"
                                class="car-model-card @(_car.Key == model.Key ? "selected" : "")"
                                @onclick="() => SelectCar(model)">
                            <span class="car-model-name">@model.Name</span>
                            <span class="car-model-meta">@Language.T("3D preview ready")</span>
                        </button>
                    }
                </div>

                <label class="field-label">@Language.T("Your colour")</label>
                <div class="color-swatch-row mb-4">
                    @foreach (var c in _carColors)
                    {
                        var col = c;
                        <button type="button"
                                class="color-swatch @(_bodyColor == col ? "selected" : "")"
                                style="background:@col"
                                @onclick="() => SelectColor(col)"
                                aria-label="@col"></button>
                    }
                    <label class="color-swatch color-swatch-custom" style="background:@_bodyColor">
                        <input type="color" value="@_bodyColor"
                               @oninput="OnCustomColor" />
                    </label>
                </div>

                <label class="field-label">@Language.T("Your size")</label>
                <div class="size-grid">
                    @foreach (var s in Sizes.All)
                    {
                        var size = s;
                        <button type="button"
                                class="size-card @(_config.SizeKey == size.Key ? "selected" : "")"
                                @onclick="() => SelectSize(size)">
                            <span class="size-name">@Language.T(size.Name)</span>
                            <span class="size-dims">@size.Dimensions</span>
                            <span class="size-blurb">@Language.T(size.Blurb)</span>
                            <span class="size-price">@size.BasePrice.ToString("C2")</span>
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="studio-bar">
    <div class="container studio-bar-inner">
        <div class="studio-bar-spec">
            <span class="studio-bar-title">@Language.T("Your") @Language.T(_config.Size.Name)</span>
            <span class="studio-bar-sub">@_car.Name · @_config.Size.Dimensions</span>
        </div>
        <div class="d-flex align-items-center gap-3">
            @if (_added)
            {
                <span class="studio-bar-added"><i class="bi bi-bag-check-fill"></i> @Language.T("It's yours — added!")</span>
            }
            <span class="studio-bar-price">@_config.Price.ToString("C2")</span>
            <button class="btn-accent-c" @onclick="AddToBag">
                <i class="bi bi-bag-plus"></i> @Language.T("Add to cart")
            </button>
        </div>
    </div>
</div>

@code {
    private bool _added;
    private string _bodyColor = "#2D6CFF";
    private CarModel _car = CarCatalog.Default;
    private readonly StudioConfig _config = new();

    private readonly string[] _carColors =
    {
        "#16161a", "#f4f6f9", "#c81f0c", "#1741b8", "#9aa3b0", "#1d7a46", "#e0a020",
    };

    protected override void OnInitialized() => Language.OnChange += StateHasChanged;

    private string HeadingNoun => Language.T(_config.Size.AllowsText ? "keychain" : "figure");

    private void SelectCar(CarModel car) { _car = car; _added = false; }

    private void SelectSize(SizeOption size) { _config.SizeKey = size.Key; _added = false; }

    private void SelectColor(string color) { _bodyColor = color; _added = false; }

    private void OnCustomColor(ChangeEventArgs e) { _bodyColor = e.Value?.ToString() ?? _bodyColor; _added = false; }

    private void AddToBag()
    {
        var product = new Product
        {
            Id = $"custom-{Guid.NewGuid():N}",
            Name = $"Custom {_car.Name} {_config.Size.Name}",
            Description = $"A 3D-printed {_car.Name} {_config.Size.Name.ToLower()} in {_config.Material.Name}.",
            Price = _config.Price,
            ImageUrl = string.Empty,
            Category = "Custom",
            DefaultMaterial = _config.Material.Name,
            TileClass = _config.Material.Css,
            Filament = _config.Material.Name,
            CustomText = null,
            Dimensions = _config.Size.Dimensions
        };

        CartService.AddItem(product, _config.Material.Name);
        _added = true;
    }

    public void Dispose() => Language.OnChange -= StateHasChanged;
}
