@page "/checkout"
@using MyMiniCar.Web.Services
@inject CartService CartService
@inject CheckoutService CheckoutService
@inject ShippingService ShippingService
@inject LanguageService Language
@inject NavigationManager Navigation
@implements IDisposable

<div class="container py-5">
    <div class="text-center mb-5">
        <span class="eyebrow">@Language.T("Checkout")</span>
        <h1 class="mt-3 mb-2">@Language.T("Almost there")</h1>
        <p class="text-soft mx-auto" style="max-width: 30rem;">
            @Language.T("Enter your details, choose Econt delivery, then pay securely with card. We print to order in 3–5 days.")
        </p>
    </div>

    @if (!CartService.Items.Any())
    {
        <div class="studio-panel text-center py-5 mx-auto" style="max-width: 30rem;">
            <i class="bi bi-bag" style="font-size: 2.4rem; color: var(--ink-faint);"></i>
            <p class="mt-3 text-soft">@Language.T("Your cart is empty.")</p>
            <button class="btn-primary-c mt-2" @onclick="@(() => Navigation.NavigateTo("products"))">@Language.T("Browse keychains")</button>
        </div>
    }
    else
    {
        <div class="row g-4 g-lg-5">
            <div class="col-lg-7">
                <div class="studio-panel">
                    @if (Canceled == "true")
                    {
                        <div class="alert-c mb-4" style="background: rgba(255,74,46,0.08); color: var(--accent-600); border-color: rgba(255,74,46,0.3);">
                            <i class="bi bi-info-circle"></i> @Language.T("Payment was canceled — your cart is still here whenever you're ready.")
                        </div>
                    }
                    @if (_error is not null)
                    {
                        <div class="alert-c mb-4" style="background: rgba(255,74,46,0.08); color: var(--accent-600); border-color: rgba(255,74,46,0.3);">
                            <i class="bi bi-exclamation-triangle"></i> @_error
                        </div>
                    }

                    <div class="studio-step-title"><span class="studio-step-num"><i class="bi bi-person"></i></span> @Language.T("Your details")</div>

                    <label class="field-label">@Language.T("Email")</label>
                    <input class="input-c mb-3" type="email" placeholder="you@email.com" @bind="_email" />

                    <label class="field-label">@Language.T("Full name")</label>
                    <input class="input-c mb-3" placeholder="Jane Driver" @bind="_name" />

                    <label class="field-label">@Language.T("Phone")</label>
                    <input class="input-c" placeholder="0888 123 456" @bind="_phone" />

                    <div class="studio-step-title mt-4"><span class="studio-step-num"><i class="bi bi-truck"></i></span> @Language.T("Delivery")</div>

                    <div class="d-flex gap-2 mb-3">
                        <button type="button" class="@DeliveryTabClass("address")" @onclick='() => SetDeliveryMode("address")'>
                            <i class="bi bi-house-door"></i> @Language.T("To address")
                        </button>
                        <button type="button" class="@DeliveryTabClass("office")" @onclick='() => SetDeliveryMode("office")'>
                            <i class="bi bi-shop"></i> @Language.T("To Econt office")
                        </button>
                    </div>

                    <label class="field-label">@Language.T("City")</label>
                    @if (_citiesLoading)
                    {
                        <div class="input-c d-flex align-items-center text-faint"><span class="spinner-c"></span> <span class="ms-2">@Language.T("Loading cities...")</span></div>
                    }
                    else
                    {
                        <select class="input-c" @bind="_selectedCityId" @bind:after="OnCityChanged">
                            <option value="">@Language.T("— select a city —")</option>
                            @foreach (var c in CityOptions)
                            {
                                <option value="@c.Id">@CityDisplay(c)</option>
                            }
                        </select>
                    }

                    @if (_deliveryMode == "address")
                    {
                        <label class="field-label mt-3">@Language.T("Address")</label>
                        <input class="input-c" placeholder='@Language.T("Street, number, floor — anything a courier can find")' @bind="_address" />
                    }
                    else
                    {
                        <label class="field-label mt-3">@Language.T("Office")</label>
                        @if (_officesLoading)
                        {
                            <div class="input-c d-flex align-items-center text-faint"><span class="spinner-c"></span> <span class="ms-2">@Language.T("Loading offices...")</span></div>
                        }
                        else if (_offices.Any())
                        {
                            <select class="input-c" @bind="_selectedOfficeCode" @bind:after="OnOfficeChanged">
                                <option value="">@Language.T("— select an office —")</option>
                                @foreach (var office in _offices)
                                {
                                    <option value="@office.Code">@office.Name — @office.Address</option>
                                }
                            </select>
                        }
                        else if (_selectedCity is not null)
                        {
                            <p class="text-faint" style="font-size: 0.8rem;">@Language.T("No Econt offices in this city. Try delivery to address instead.")</p>
                        }
                        else
                        {
                            <p class="text-faint" style="font-size: 0.8rem;">@Language.T("Choose a city first to list its offices.")</p>
                        }
                    }

                    @if (_quoteLoading)
                    {
                        <p class="text-faint text-center mt-4 mb-0" style="font-size: 0.78rem;"><span class="spinner-c"></span> <span>@Language.T("Calculating Econt delivery...")</span></p>
                    }
                    else if (_quoteNote is not null)
                    {
                        <p class="text-faint text-center mt-4 mb-0" style="font-size: 0.78rem;">@_quoteNote</p>
                    }

                    <button class="btn-accent-c btn-block btn-lg mt-3" disabled="@(_busy || !CanPay)" @onclick="Pay">
                        @if (_busy)
                        {
                            <span class="spinner-c"></span> <span>@Language.T("Redirecting to secure checkout...")</span>
                        }
                        else
                        {
                            <i class="bi bi-lock-fill"></i>
                            <span>@Language.T("Pay") @Fmt(Total)</span>
                        }
                    </button>
                    <p class="text-center text-faint mt-3 mb-0" style="font-size: 0.74rem;">
                        <i class="bi bi-shield-lock"></i> @Language.T("Payments processed securely by Stripe. Test mode — use card 4242 4242 4242 4242.")
                    </p>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="studio-panel">
                    <div class="studio-step-title"><span class="studio-step-num"><i class="bi bi-bag"></i></span> @Language.T("Order summary")</div>

                    <div class="order-lines">
                        @foreach (var item in CartService.Items)
                        {
                            <div class="order-line">
                                <div class="order-line-img @item.Product.TileClass">
                                    @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" alt="@Language.ProductName(item.Product)" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-car-front-fill"></i>
                                    }
                                    <span class="order-line-qty">@item.Quantity</span>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="order-line-name">@Language.ProductName(item.Product)</div>
                                    <div class="text-faint" style="font-size: 0.78rem;">@Language.T(item.SelectedMaterial)</div>
                                </div>
                                <div class="order-line-price">@Fmt(item.Product.Price * item.Quantity)</div>
                            </div>
                        }
                    </div>

                    <div class="order-totals">
                        <div class="d-flex justify-content-between">
                            <span class="text-soft">@Language.T("Subtotal")</span>
                            <span>@Fmt(Subtotal)</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-soft">@Language.T("Shipping")</span>
                            <span>@ShippingLabel</span>
                        </div>
                        <div class="d-flex justify-content-between order-grand">
                            <span>@Language.T("Total")</span>
                            <span>@Fmt(Total)</span>
                        </div>
                    </div>

                    @if (Subtotal < FreeShippingThreshold && _quote is null)
                    {
                        <p class="text-faint text-center mt-3 mb-0" style="font-size: 0.74rem;">
                            @Language.T("Add") @Fmt(FreeShippingThreshold - Subtotal) @Language.T("more for free shipping, or calculate Econt delivery above.")
                        </p>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private const decimal FreeShippingThreshold = 40m;

    [Parameter]
    [SupplyParameterFromQuery(Name = "canceled")]
    public string? Canceled { get; set; }

    private string _email = string.Empty;
    private string _name = string.Empty;
    private string _phone = string.Empty;

    private string _deliveryMode = "address";

    private List<EcontCity> _allCities = new();
    private bool _citiesLoading = true;
    private int? _selectedCityId;
    private EcontCity? _selectedCity;

    private string _address = string.Empty;
    private const string Country = "Bulgaria";

    private List<EcontOffice> _offices = new();
    private bool _officesLoading;
    private string _selectedOfficeCode = string.Empty;

    private ShippingQuote? _quote;
    private bool _quoteLoading;
    private string? _quoteNote;

    private bool _busy;
    private string? _error;

    private decimal Subtotal => CartService.GetTotal();
    private bool FreeShipping => Subtotal >= FreeShippingThreshold;
    private decimal Shipping => FreeShipping ? 0m : (_quote?.Price ?? 0m);
    private decimal Total => Subtotal + Shipping;

    private double WeightKg => Math.Max(0.1, CartService.Items.Sum(i => i.Quantity * i.Product.WeightGrams) / 1000.0);

    private string ShippingLabel => FreeShipping
        ? Language.T("Free")
        : _quote is null ? "—" : Fmt(_quote.Price);

    private bool DeliveryReady => _selectedCity is not null && (_deliveryMode == "office"
        ? !string.IsNullOrEmpty(_selectedOfficeCode)
        : !string.IsNullOrWhiteSpace(_address));

    private bool CanPay =>
        !string.IsNullOrWhiteSpace(_email)
        && !string.IsNullOrWhiteSpace(_phone)
        && CartService.Items.Any()
        && DeliveryReady
        && (FreeShipping || _quote is not null);

    private IEnumerable<EcontCity> CityOptions =>
        _deliveryMode == "office"
            ? _allCities.Where(c => c.HasOffice)
            : _allCities.Where(c => c.HasDoorDelivery);

    private static string CityDisplay(EcontCity c) =>
        string.IsNullOrEmpty(c.Region) ? $"{c.Name} ({c.PostCode})" : $"{c.Name}, {c.Region} ({c.PostCode})";

    private static string Fmt(decimal value) => $"€{value:0.00}";

    private string DeliveryTabClass(string mode) =>
        _deliveryMode == mode ? "btn-primary-c flex-grow-1" : "btn-ghost-c flex-grow-1";

    protected override async Task OnInitializedAsync()
    {
        CartService.OnChange += StateHasChanged;
        Language.OnChange += StateHasChanged;
        _allCities = await ShippingService.GetCitiesAsync();
        _citiesLoading = false;
    }

    private void SetDeliveryMode(string mode)
    {
        if (_deliveryMode == mode) return;
        _deliveryMode = mode;
        _selectedCityId = null;
        _selectedCity = null;
        _selectedOfficeCode = string.Empty;
        _offices = new();
        ResetQuote();
    }

    private void ResetQuote()
    {
        _quote = null;
        _quoteNote = null;
    }

    private async Task OnCityChanged()
    {
        _selectedCity = _selectedCityId is int id ? _allCities.FirstOrDefault(c => c.Id == id) : null;
        _selectedOfficeCode = string.Empty;
        _offices = new();
        ResetQuote();

        if (_selectedCity is null) return;

        if (_deliveryMode == "office")
            await LoadOffices();
        else
            await GetQuote();
    }

    private async Task OnOfficeChanged()
    {
        ResetQuote();
        if (!string.IsNullOrEmpty(_selectedOfficeCode))
            await GetQuote();
    }

    private async Task LoadOffices()
    {
        if (_selectedCity is null) return;
        _officesLoading = true;
        _offices = await ShippingService.GetOfficesAsync(_selectedCity.Id);
        _officesLoading = false;
    }

    private async Task GetQuote()
    {
        _quoteNote = null;
        _quoteLoading = true;

        var request = new ShippingQuoteRequest(
            DeliveryMode: _deliveryMode,
            OfficeCode: _deliveryMode == "office" ? _selectedOfficeCode : null,
            CityName: _selectedCity?.Name,
            PostCode: _selectedCity?.PostCode,
            Street: _deliveryMode == "office" ? null : _address,
            Num: null,
            WeightKg: WeightKg);

        var quote = await ShippingService.GetQuoteAsync(request);
        _quoteLoading = false;

        if (quote is null)
        {
            _quote = new ShippingQuote(5.90m, "EUR");
            _quoteNote = Language.T("Couldn't reach Econt just now — applying a standard €5.90 rate.");
        }
        else
        {
            _quote = quote;
            _quoteNote = FreeShipping
                ? Language.T("Your order qualifies for free shipping — Econt cost is covered.")
                : $"{Language.T("Econt delivery:")} {Fmt(quote.Price)}.";
        }
    }

    private async Task Pay()
    {
        _error = null;
        _busy = true;

        var request = new CreateCheckoutRequest(
            Items: CartService.Items.Select(i => new CheckoutItem(
                Name: Language.ProductName(i.Product),
                Description: string.IsNullOrWhiteSpace(i.SelectedMaterial) ? null : $"{Language.T(i.SelectedMaterial)} PLA",
                UnitAmount: i.Product.Price,
                Quantity: i.Quantity)).ToList(),
            Email: _email,
            Name: _name,
            Phone: _phone,
            Address: _deliveryMode == "office" ? $"Econt office {_selectedOfficeCode}" : _address,
            City: _selectedCity?.Name,
            PostalCode: _selectedCity?.PostCode,
            Country: Country,
            DeliveryMode: _deliveryMode,
            OfficeCode: _deliveryMode == "office" ? _selectedOfficeCode : null,
            ShippingAmount: Shipping,
            WeightKg: WeightKg,
            ReturnBaseUrl: Navigation.BaseUri);

        try
        {
            var result = await CheckoutService.CreateSessionAsync(request);
            if (result is null || string.IsNullOrEmpty(result.Url))
            {
                _error = Language.T("We couldn't start the payment. Please make sure the payments service is running and try again.");
                _busy = false;
                return;
            }

            Navigation.NavigateTo(result.Url, forceLoad: true);
        }
        catch (Exception)
        {
            _error = Language.T("We couldn't reach the payments service. Please try again in a moment.");
            _busy = false;
        }
    }

    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
        Language.OnChange -= StateHasChanged;
    }
}
